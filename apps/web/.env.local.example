# 브라우저 API는 /api/huma/* 동일 출처 프록시 사용 (NEXT_PUBLIC 불필요)
# Next 서버 → 백엔드 (Vercel·로컬 dev 필수)
# 신규 API(나레이션 등) 로컬 테스트: localhost + apps/server npm run dev
HUMA_API_URL=http://localhost:3100
NEXT_PUBLIC_HUMA_API_URL=http://localhost:3100
# i7 LAN (배포·재시작 후):
# HUMA_API_URL=http://172.30.1.96:3100
# NEXT_PUBLIC_HUMA_API_URL=http://172.30.1.96:3100
# 외부 터널:
# HUMA_API_URL=https://api.romang-ai.com
HUMA_API_SECRET=your_secret_key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
