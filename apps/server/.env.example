# Server
PORT=3100
HUMA_API_SECRET=your_secret_key

# Cloudflare Tunnel (Vercel → i7 API)
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# 브라우저 프로필 (launchPersistentContext)
HUMA_PROFILES_DIR=/data/browser-profiles
# 워밍업 실패 스크린샷 로컬 저장 (Supabase huma-media/warmup-debug/ 업로드 시도)
# HUMA_WARMUP_DEBUG_DIR=/tmp/huma-warmup-debug

# Supabase (연운 프로젝트 service_role)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxx...

# Redis (v3.10 단일 i7: localhost)
REDIS_URL=redis://localhost:6379
# Windows/로컬 dev — SOCKS 동글 없을 때 C-Rank 스케줄러 probe 스킵 (API hang 방지)
# C-Rank·스케줄러 SOCKS probe 전부 끔 (프록시만 정상·C-Rank DB error일 때 임시 사용)
# HUMA_SKIP_CRANK_PROBE=1
# LTE 동글 SOCKS naver probe 타임아웃(ms). i7에서 30초+ 성공 시 기본 45000
# HUMA_MODEM_SOCKS_PROBE_TIMEOUT_MS=45000
# v3.9 레거시 분산 워커: REDIS_HOST=마스터 LAN IP
# REDIS_HOST=192.168.0.10
# REDIS_PORT=6379

# v3.9 레거시 — 2대 분산 시 워커 전용 (API 없음)
# HUMA_WORKER_CONCURRENCY=3
# 암호화
ENCRYPTION_KEY=32자리_랜덤_문자열

# JWT 인증
JWT_SECRET=64자리_랜덤_문자열
JWT_EXPIRES_IN=8h

# Google Imagen 4 (v3.26 이미지 전용 — Gemini API 키 공유)
GOOGLE_AI_API_KEY=your_google_ai_api_key
# IMAGEN_MODEL=imagen-4.0-fast-generate-001  # 비우면 Haiku가 fast/standard 자동 판단

# Higgsfield Cloud API (v3.26 영상 전용 — Kling 3.0)
# Keys/Billing: cloud.higgsfield.ai · REST: platform.higgsfield.ai
HIGGSFIELD_API_KEY_ID=your_api_key_id
HIGGSFIELD_API_KEY_SECRET=your_api_key_secret
# HIGGSFIELD_API_BASE=https://platform.higgsfield.ai
# (레거시) 단일 변수: id:secret 조합 또는 Bearer 토큰
# HIGGSFIELD_API_KEY=your_key_id:your_key_secret

/** 소셜 API 토큰·앱 키 — 워크스페이스별 (_YEONUN / _QUIZOASIS / _PANANA). 전역 키는 폴백 */

# TikTok (워크스페이스별 OAuth 앱 + 채널 토큰)
TIKTOK_CLIENT_KEY_YEONUN=xxx
TIKTOK_CLIENT_SECRET_YEONUN=xxx
TIKTOK_ACCESS_TOKEN_YEONUN=xxx
# TIKTOK_REFRESH_TOKEN_YEONUN=xxx

TIKTOK_CLIENT_KEY_QUIZOASIS=xxx
TIKTOK_CLIENT_SECRET_QUIZOASIS=xxx
TIKTOK_ACCESS_TOKEN_QUIZOASIS=xxx

TIKTOK_CLIENT_KEY_PANANA=xxx
TIKTOK_CLIENT_SECRET_PANANA=xxx
TIKTOK_ACCESS_TOKEN_PANANA=xxx

# Instagram / Threads (Meta Graph — 워크스페이스별)
META_APP_ID_YEONUN=xxx
META_APP_SECRET_YEONUN=xxx
META_ACCESS_TOKEN_YEONUN=xxx
META_IG_USER_ID_YEONUN=xxx
META_THREADS_USER_ID_YEONUN=xxx

META_APP_ID_QUIZOASIS=xxx
META_APP_SECRET_QUIZOASIS=xxx
META_ACCESS_TOKEN_QUIZOASIS=xxx
META_IG_USER_ID_QUIZOASIS=xxx
META_THREADS_USER_ID_QUIZOASIS=xxx
# 퀴즈 EN/KR IG 분리 시:
# META_IG_USER_ID_EN_QUIZOASIS=xxx
# META_IG_USER_ID_KR_QUIZOASIS=xxx

META_APP_ID_PANANA=xxx
META_APP_SECRET_PANANA=xxx
META_ACCESS_TOKEN_PANANA=xxx
META_IG_USER_ID_PANANA=xxx
META_THREADS_USER_ID_PANANA=xxx

# X (Twitter) — 워크스페이스별
TWITTER_API_KEY_YEONUN=xxx
TWITTER_API_SECRET_YEONUN=xxx
TWITTER_ACCESS_TOKEN_YEONUN=xxx
TWITTER_ACCESS_SECRET_YEONUN=xxx

TWITTER_API_KEY_QUIZOASIS=xxx
TWITTER_API_SECRET_QUIZOASIS=xxx
TWITTER_ACCESS_TOKEN_QUIZOASIS=xxx
TWITTER_ACCESS_SECRET_QUIZOASIS=xxx

TWITTER_API_KEY_PANANA=xxx
TWITTER_API_SECRET_PANANA=xxx
TWITTER_ACCESS_TOKEN_PANANA=xxx
TWITTER_ACCESS_SECRET_PANANA=xxx

# 레거시 전역 폴백 (워크스페이스 키 없을 때만)
# TIKTOK_CLIENT_KEY=xxx
# META_APP_ID=xxx
# TWITTER_API_KEY=xxx

# Pinterest (퀴즈오아시스 Video Pin)
PINTEREST_CLIENT_ID=your_pinterest_client_id
PINTEREST_CLIENT_SECRET=your_pinterest_client_secret
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token
PINTEREST_BOARD_ID=your_quizoasis_board_id

# YouTube Data API v3 (서비스별 OAuth refresh_token)
YOUTUBE_CLIENT_ID_YEONUN=your_client_id
YOUTUBE_CLIENT_SECRET_YEONUN=your_client_secret
YOUTUBE_REFRESH_TOKEN_YEONUN=your_refresh_token

YOUTUBE_CLIENT_ID_QUIZOASIS=your_client_id
YOUTUBE_CLIENT_SECRET_QUIZOASIS=your_client_secret
YOUTUBE_REFRESH_TOKEN_QUIZOASIS=your_refresh_token

YOUTUBE_CLIENT_ID_PANANA=your_client_id
YOUTUBE_CLIENT_SECRET_PANANA=your_client_secret
YOUTUBE_REFRESH_TOKEN_PANANA=your_refresh_token
# 할당량: 10,000 units/일, 업로드 1,600 units/건 → 서비스당 2건/일

# 영상 콘텐츠 — Telegram 알림 링크·파나나 캐릭터 동기화·EvoLink 콜백
HUMA_WEB_URL=https://your-huma-web-url
HUMA_SERVER_URL=https://your-huma-api-url
PANANA_CHARACTER_API_URL=https://panana-api.example.com/characters

# EvoLink Kling 3.0 Turbo (영상 콘텐츠 생성)
EVOLINK_API_KEY=your_evolink_api_key
# EVOLINK_API_BASE=https://api.evolink.ai

# AdSense Management API (퀴즈오아시스 — GOOGLE_ADSENSE_* 별칭도 지원)
ADSENSE_CLIENT_ID=your_client_id
ADSENSE_CLIENT_SECRET=your_client_secret
ADSENSE_REFRESH_TOKEN=your_refresh_token
ADSENSE_ACCOUNT_ID=pub-xxxxxxxxxxxxxxxx
# GOOGLE_ADSENSE_CLIENT_ID / GOOGLE_ADSENSE_CLIENT_SECRET / GOOGLE_ADSENSE_REFRESH_TOKEN
# ADSENSE_PUBLISHER_ID=pub-xxxxxxxxxxxxxxxx

# Claude API (메인 콘텐츠 생성 · Haiku 서브: 해시태그·URL 요약·autoDecide)
ANTHROPIC_API_KEY=your_anthropic_api_key

# 알림
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# 네이버 카페 점사모
JEOMSAMO_CLUB_ID=카페ID
JEOMSAMO_MENU_ID=게시판ID

# huma 웹 (Telegram·큐 링크)
HUMA_WEB_URL=https://romang-ai.com

# Telegram CAPTCHA 알림 + 답장으로 정답 원격 입력 (서버 getUpdates 폴링, i7 production만)
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID_YEONUN=6541135704
TELEGRAM_CHAT_ID_QUIZ_PANANA=-5162369222
# TELEGRAM_INBOUND_POLL=true  — i7 PM2 (NODE_ENV=production) 기본 활성. dev PC에서 npm run dev 시 자동 OFF
# TELEGRAM_INBOUND_POLL=false — 폴링 강제 OFF (알림만, 답장 수신 안 함)

# Layer4 1차 CAPTCHA 휴식 시간 (기본 24). is_active 수동 true 전까지 crank 제외
# HUMA_LAYER4_CAPTCHA_REST_HOURS=24

# VNC — RealVNC Direct (x11vnc :5900, LAN) · Xvfb 2560×1080 3열 타일
# HUMA_VNC_SHOW_POINTER=false — 자동화 마우스 오버레이 끔 (기본 켜짐)
# HUMA_VNC_X11_CURSOR=false — xdotool X11 커서 동기화 끔 (xdotool 없으면 자동 스킵)
# i7 Xvfb(:99) Chromium GL — swiftshader(기본, CPU·빈화면 적음) | angle | desktop
# HUMA_CHROMIUM_GL=swiftshader
# HUMA_VNC_WIDTH=2560
# HUMA_VNC_HEIGHT=1080
# HUMA_VNC_URL_YEONUN=vnc://172.30.1.96:5900
# VNC — Tailscale (집 밖) — i7: bash deploy/setup-tailscale.sh 후 자동 기입
# HUMA_VNC_URL_YEONUN=vnc://100.x.x.x:5900
# HUMA_VNC_URL_QUIZ_PANANA=vnc://100.x.x.x:5900
