[Unit]
Description=Cloudflare Tunnel for HUMA Studio API
After=network-online.target huma-server.service
Wants=network-online.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/cloudflared tunnel --config /etc/cloudflared/config.yml run
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=cloudflared-huma

[Install]
WantedBy=multi-user.target
