{
  "name": "huma-studio",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build --filter=@huma/web --filter=@huma/server",
    "build:web": "turbo build --filter=@huma/web",
    "lint": "turbo lint",
    "clean:dev": "node scripts/dev-clean.mjs",
    "dev:web": "npm run dev --workspace=@huma/web",
    "dev:server": "npm run dev --workspace=@huma/server"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "playwright": "1.49.1",
    "playwright-core": "1.49.1"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "playwright": "1.49.1",
    "playwright-core": "1.49.1",
    "playwright-extra": {
      "playwright": "1.49.1",
      "playwright-core": "1.49.1"
    }
  },
  "packageManager": "npm@10.8.2"
}
